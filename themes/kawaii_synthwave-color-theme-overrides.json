  "tokenColors": [
    {
      "name": "Punctuation within templates",
      "scope": "string.template meta.embedded.line",
      "settings": {
        "foreground": "#b8b0b4"
      }
    },
    {
      "name": "Key-value separator",
      "scope": "punctuation.separator.key-value",
      "settings": {
        "foreground": "#b8b0b4"
      }
    },
    {
      "name": "Markup text",
      "scope": [
        "text.html",
        "keyword.operator.assignment"
      ],
      "settings": {
        "foreground": "#fffafdEE"
      }
    },
    {
      "name": "Markup quote",
      "scope": "markup.quote",
      "settings": {
        "foreground": "#b8b0b4cc",
        "fontStyle": "italic"
      }
    }
  ],
  "semanticTokenColors": {
    "newOperator": "#fede5d",
    "stringLiteral": "#ff8b39",
    "customLiteral": "#ff7edb",
    "numberLiteral": "#f97e72"
  }
